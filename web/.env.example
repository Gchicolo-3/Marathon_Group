# Neon Postgres connection string (same one used by the pipeline agents' db/client.js)
# e.g. postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Shared password for the dashboard gate (no full auth system in v1)
DASHBOARD_PASSWORD=

# Perplexity API key — powers the prospector's live web search for real
# contacts and the news agent's trigger-event scan. Without it those two
# steps error out (visible on /runs); the rest of the pipeline still runs.
PERPLEXITY_API_KEY=
